POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag

IMAGE_TAG=latest

# Health probes and Prometheus-compatible metrics.
OBSERVABILITY_ADDR=:9090

# OpenTelemetry traces. Leave the endpoint empty to disable trace export.
# Jaeger accepts OTLP on port 4317; an OpenTelemetry Collector can be used here as well.
OTEL_SERVICE_NAME=
APP_VERSION=dev
DEPLOYMENT_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_TRACES_SAMPLER_ARG=0.1

# Source connections and credentials are managed through the Sources UI.
SOURCE_PAGE_LIMIT=50

# GitLab indexing policy. GitLab connections/tokens are added through Sources UI.
GITLAB_MAX_FILE_BYTES=1048576
GITLAB_MAX_API_PAGES=1000
GITLAB_EXCLUDED_DIRS=.git,vendor,node_modules,dist,build,target,.next,.nuxt,coverage
GITLAB_EXCLUDED_FILES=.env,.env.*,id_rsa,id_ed25519,credentials.json,secrets.yml,*.pem,*.key,*.p12,*.jks
GITLAB_TEXT_EXTENSIONS=.go,.py,.js,.jsx,.ts,.tsx,.vue,.java,.kt,.kts,.rb,.php,.cs,.c,.h,.cpp,.hpp,.rs,.swift,.scala,.sh,.bash,.zsh,.sql,.md,.txt,.rst,.adoc,.yaml,.yml,.json,.toml,.xml,.html,.css,.scss,.less,.proto,.graphql,.tf,.hcl,.gradle,.properties,.ini,.conf,.dockerfile

EMBEDDINGS_BASE_URL=http://ollama:11434/v1
EMBEDDINGS_API_KEY=ollama
EMBEDDINGS_MODEL=bge-m3
EMBEDDINGS_DIM=1024
EMBEDDINGS_SEND_DIMENSION=true
EMBEDDINGS_SKIP_TLS_VERIFY=false

LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:14b
LLM_TEMPERATURE=0.1
LLM_SKIP_TLS_VERIFY=false

CHUNK_SIZE=900
CHUNK_OVERLAP=180
SEARCH_TOP_K=8
SEARCH_VECTOR_WEIGHT=0.60
SEARCH_KEYWORD_WEIGHT=0.40
WORKER_POLL_SECONDS=5
